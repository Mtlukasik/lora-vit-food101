 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# LoRA Fine-tuning of ViT-B/16 on Food-101\n",
    "\n",
    "Replicates [rezaakb/peft-vit](https://github.com/rezaakb/peft-vit).  \n",
    "Base model: `google/vit-base-patch16-224-in21k` (frozen, 85.9M params)  \n",
    "Trainable: LoRA matrices on attention q/v layers (~301K params for r=4)\n",
    "\n",
    "**Make sure Runtime → Change runtime type → T4 GPU is selected before running.**"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Check GPU"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!nvidia-smi"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Clone repos"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "\n",
    "# Clone the original peft-vit repo (contains main.py + src/)\n",
    "if not os.path.exists('peft-vit'):\n",
    "    !git clone https://github.com/rezaakb/peft-vit\n",
    "\n",
    "# Clone YOUR repo for configs\n",
    "# TODO: replace with your GitHub username/repo\n",
    "YOUR_REPO = 'YOUR_USERNAME/lora-vit-food101'\n",
    "if not os.path.exists('lora-vit-food101'):\n",
    "    !git clone https://github.com/{YOUR_REPO}\n",
    "\n",
    "# Work from inside peft-vit but use our configs\n",
    "os.chdir('peft-vit')\n",
    "print('Working dir:', os.getcwd())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Install dependencies"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install -q -r requirements.txt\n",
    "# peft might not be in original requirements — add explicitly\n",
    "!pip install -q peft>=0.4.0 lightning>=2.0.0"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Copy our configs into the peft-vit tree"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import shutil, os\n",
    "\n",
    "src_configs = '../lora-vit-food101/configs/lora'\n",
    "dst_configs = 'configs/lora'\n",
    "os.makedirs(dst_configs, exist_ok=True)\n",
    "\n",
    "for f in os.listdir(src_configs):\n",
    "    shutil.copy(os.path.join(src_configs, f), os.path.join(dst_configs, f))\n",
    "    print(f'Copied {f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Choose LoRA rank and train"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Choose: food101_r4 (~301K params), food101_r8 (~448K), food101_r16 (~743K)\n",
    "CONFIG = 'configs/lora/food101_r4.yaml'\n",
    "\n",
    "!python main.py fit --config {CONFIG}"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Evaluate the best checkpoint"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import glob\n",
    "\n",
    "# Find latest checkpoint\n",
    "ckpts = glob.glob('outputs/**/checkpoints/*.ckpt', recursive=True)\n",
    "if not ckpts:\n",
    "    ckpts = glob.glob('lightning_logs/**/checkpoints/*.ckpt', recursive=True)\n",
    "\n",
    "if ckpts:\n",
    "    latest_ckpt = sorted(ckpts)[-1]\n",
    "    print(f'Evaluating: {latest_ckpt}')\n",
    "    \n",
    "    # Find config saved alongside checkpoint\n",
    "    config_dir = os.path.dirname(os.path.dirname(latest_ckpt))\n",
    "    saved_config = os.path.join(config_dir, 'config.yaml')\n",
    "    \n",
    "    if os.path.exists(saved_config):\n",
    "        !python main.py test --ckpt_path {latest_ckpt} --config {saved_config}\n",
    "    else:\n",
    "        print(f'No saved config found at {saved_config}, using original config')\n",
    "        !python main.py test --ckpt_path {latest_ckpt} --config {CONFIG}\n",
    "else:\n",
    "    print('No checkpoint found. Did training complete?')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. (Optional) Quick parameter count check"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Stand-alone parameter counter — no training required\n",
    "from transformers import ViTModel\n",
    "from peft import LoraConfig, get_peft_model\n",
    "\n",
    "base = ViTModel.from_pretrained('google/vit-base-patch16-224-in21k')\n",
    "\n",
    "for r in [4, 8, 16]:\n",
    "    lora_cfg = LoraConfig(\n",
    "        r=r,\n",
    "        lora_alpha=r * 2,\n",
    "        target_modules=['query', 'value'],\n",
    "        lora_dropout=0.1,\n",
    "        bias='none',\n",
    "    )\n",
    "    model = get_peft_model(base, lora_cfg)\n",
    "    trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "    total     = sum(p.numel() for p in model.parameters())\n",
    "    print(f'r={r:2d}  trainable={trainable/1e3:.1f}K  total={total/1e6:.1f}M  ({100*trainable/total:.2f}%)')\n",
    "    # reset for next iteration\n",
    "    base = ViTModel.from_pretrained('google/vit-base-patch16-224-in21k')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
